{
  "name": "job-pipeline-llm-eval",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker harness for benchmarking non-Claude LLMs against the Claude baseline on job scoring (cost + latency + quality).",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create job-pipeline-llm-eval",
    "db:migrate:local": "wrangler d1 execute job-pipeline-llm-eval --local --file=./schema.sql",
    "db:migrate": "wrangler d1 execute job-pipeline-llm-eval --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "typescript": "^5",
    "wrangler": "^4.20.0"
  }
}
